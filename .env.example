# Copy this file to .env.local and fill in real values for local dev.
# In Vercel, set the same keys via the project's Environment Variables page.

# --- Financial data ---
# https://financialmodelingprep.com/developer
FMP_API_KEY=your_fmp_api_key_here

# --- Supabase (auth + database) ---
# Project URL and publishable anon key — safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Server-only key with full DB access. Never commit. Used by the Stripe
# webhook + checkout routes to write user_profiles bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Stripe (subscriptions + billing portal) ---
STRIPE_SECRET_KEY=sk_test_or_live_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_or_live_publishable
# Webhook signing secret from the Stripe dashboard (per-environment).
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Stripe Price IDs — one per (plan, interval) pair.
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly
STRIPE_PRO_ANNUAL_PRICE_ID=price_pro_annual
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_premium_monthly
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_premium_annual

# --- AI summaries ("What's Happening" panel) ---
# Perplexity Sonar API key for the per-stock business brief.
# Optional: the route degrades gracefully if unset.
PERPLEXITY_API_KEY=your_perplexity_api_key_here
